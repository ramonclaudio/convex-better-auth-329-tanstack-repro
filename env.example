# Copy to .env.local. `npx convex dev` writes CONVEX_DEPLOYMENT, VITE_CONVEX_URL,
# and VITE_CONVEX_SITE_URL for you. Set BETTER_AUTH_SECRET + SITE_URL on the
# Convex deployment via `npx convex env set`.

# CONVEX_DEPLOYMENT=dev:your-project-name
# VITE_CONVEX_URL=https://your-project-name.convex.cloud
# VITE_CONVEX_SITE_URL=https://your-project-name.convex.site

# Local dev origin used by Better Auth for redirect URL validation. Match
# whatever port vite serves (defaults to 3000).
SITE_URL=http://localhost:3000
